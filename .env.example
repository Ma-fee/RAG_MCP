# SiliconFlow (shared)
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=YOUR_SILICONFLOW_API_KEY

# Embedding
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=YOUR_SILICONFLOW_API_KEY
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_TIMEOUT_SECONDS=30

# Rerank (post-v1 reserved)
RERANK_BASE_URL=https://api.siliconflow.cn/v1
RERANK_API_KEY=YOUR_SILICONFLOW_API_KEY
RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANK_TIMEOUT_SECONDS=30

# Multimodal chat (post-v1 reserved)
MULTIMODAL_BASE_URL=https://api.siliconflow.cn/v1
MULTIMODAL_API_KEY=YOUR_SILICONFLOW_API_KEY
MULTIMODAL_MODEL=zai-org/GLM-4.6V

# General chat model example
CHAT_BASE_URL=https://api.siliconflow.cn/v1
CHAT_API_KEY=YOUR_SILICONFLOW_API_KEY
CHAT_MODEL=Pro/zai-org/GLM-4.7
